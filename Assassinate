local Spawner = loadstring(game:HttpGet("https://raw.githubusercontent.com/RegularVynixu/DOORS-Entity-Spawner-V2/main/init.luau"))()

-- Creation of Assassinate
local entity = Spawner:Create({
    Entity = {
        Name = "Assassinate",
        Asset = "rbxassetid://126054995168616", -- We use a transparent base
        HeightOffset = 0
    },
    Movement = {
        Speed = 250, -- Very fast
        Delay = 2,
        Reversed = false
    },
    Damage = {
        Enabled = true,
        Range = 50,
        Amount = 150 -- Instant Death
    },
    Lights = {
        Flicker = { Enabled = true, Duration = 5 }, -- Long flashing
        Shatter = true,
        Repair = false
    },
    Earthquake = { Enabled = true },
    CameraShake = {
        Enabled = true,
        Range = 100,
        Values = {4, 30, 0.1, 2}
    }
})

if entity then
    entity:SetCallback("OnSpawned", function()
        local model = entity.Model
        if model then
            -- Visual: Purple glowing face (аура)
            local face = Instance.new("Part", model)
            face.Size = Vector3.new(5, 5, 0.1)
            face.Color = Color3.fromRGB(150, 0, 255)
            face.Material = Enum.Material.Neon
            face.CanCollide = false
            
            local attachment = Instance.new("Attachment", face)
            local particles = Instance.new("ParticleEmitter", attachment)
            particles.Color = ColorSequence.new(Color3.fromRGB(130, 0, 255))
            particles.Size = NumberSequence.new(2)
            particles.Speed = NumberRange.new(5, 10)
            
            local weld = Instance.new("Weld", face)
            weld.Part0 = model.PrimaryPart
            weld.Part1 = face
        end

        -- SENSITIVITY MECHANICS (Don't move!)
        task.spawn(function()
            local player = game.Players.LocalPlayer
            local char = player.Character
            if not char then return end
            local humRoot = char:FindFirstChild("HumanoidRootPart")
            
            while entity and entity.Model and entity.Model.Parent do
                -- If the player moves too fast (Velocity > 1)
                if humRoot and humRoot.AssemblyLinearVelocity.Magnitude > 1 then
                    -- Assassinate "hears" and flies towards the player
                    entity.Movement.Speed = 400 
                else
                    entity.Movement.Speed = 250
                end
                task.wait(0.1)
            end
        end)
    end)

    -- Adjusting rebounds (from 6 to 12 times)
    local rebounds = math.random(6, 12)
    
    entity:SetCallback("OnReachingEnd", function()
        if rebounds > 0 then
            rebounds = rebounds - 1
            task.wait(math.random(1, 3))
            entity:Run(true) -- Attacks again
        end
    end)

    -- Sound (Distorted Scream)
    entity:SetCallback("OnEnterRoom", function()
        local s = Instance.new("Sound", workspace)
        s.SoundId = "rbxassetid://9125714014" -- Aggressive sound
        s.Volume = 4
        s:Play()
        game:GetService("Debris"):AddItem(s, 5)
    end)

    entity:Run(true)
end
